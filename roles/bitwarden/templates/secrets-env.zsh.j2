# Load environment secrets pulled from Bitwarden (managed by the bitwarden role).
# Sources {{ bitwarden_env_file }} (mode 0600, never committed) and exports every
# KEY=value via `set -a`. Regenerate the values with `dotfiles secrets`.
if [ -r "{{ bitwarden_env_file }}" ]; then
  set -a
  source "{{ bitwarden_env_file }}"
  set +a
fi
