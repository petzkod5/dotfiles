#!/usr/bin/env bash
#
# dotfiles — sync this machine to the configuration in the Ansible playbook.
#
# Installed by the `cli` role as a symlink at ~/.local/bin/dotfiles -> <repo>/bin/dotfiles.
# It resolves the repo from its own real path, so it works from any cwd.
set -euo pipefail

# --- locate the repo --------------------------------------------------------
self="$(readlink -f "${BASH_SOURCE[0]}")"
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$(dirname "$self")")}"
HOST="${DOTFILES_HOST:-$(hostname)}"

# --- output helpers ---------------------------------------------------------
if [ -t 1 ]; then
  b=$'\033[1m'; g=$'\033[1;32m'; y=$'\033[1;33m'; r=$'\033[1;31m'; n=$'\033[0m'
else
  b=""; g=""; y=""; r=""; n=""
fi
say()  { printf '%s%s%s\n' "$g" "$*" "$n"; }
warn() { printf '%s%s%s\n' "$y" "$*" "$n" >&2; }
die()  { printf '%s%s%s\n' "$r" "$*" "$n" >&2; exit 1; }

# --- preflight --------------------------------------------------------------
command -v ansible-playbook >/dev/null 2>&1 \
  || die "ansible-playbook not found — run ${DOTFILES_DIR}/bootstrap.sh first."
[ -f "${DOTFILES_DIR}/site.yml" ] \
  || die "site.yml not found in ${DOTFILES_DIR} (set DOTFILES_DIR to the repo)."

# --- configuration ----------------------------------------------------------
# Optional TOML config at ~/.config/dotfiles/config.toml (override path with
# DOTFILES_CONFIG). Precedence: environment variable > config file > default.
# Parsed with Python's stdlib tomllib (needs Python >= 3.11); `dotfiles config`
# scaffolds and opens it.
DOTFILES_CONFIG="${DOTFILES_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/config.toml}"
declare -A _cfg=()
if [ -f "$DOTFILES_CONFIG" ]; then
  _cfgpy="$(command -v python3 || command -v python || true)"
  if [ -n "$_cfgpy" ]; then
    while IFS= read -r -d '' _k && IFS= read -r -d '' _v; do _cfg["$_k"]="$_v"; done \
      < <("$_cfgpy" - "$DOTFILES_CONFIG" <<'PY'
import sys
try:
    import tomllib
except ModuleNotFoundError:
    sys.stderr.write("dotfiles: config needs Python >= 3.11 (tomllib); ignoring it\n"); sys.exit(0)
try:
    with open(sys.argv[1], "rb") as fh:
        data = tomllib.load(fh)
except Exception as exc:
    sys.stderr.write("dotfiles: invalid config (%s); ignoring it\n" % exc); sys.exit(0)
def walk(prefix, d):
    for k, v in d.items():
        key = prefix + k
        if isinstance(v, dict):
            walk(key + ".", v)
        else:
            sys.stdout.write(key + "\0" + ("" if v is None else str(v)) + "\0")
walk("", data)
PY
    )
  fi
fi
cfg()  { printf '%s' "${_cfg[$1]:-}"; }
pick() { local e="$1" c; c="$(cfg "$2")"; printf '%s' "${e:-${c:-$3}}"; }

_default_prompt="Commit the changes in this dotfiles repository. Ensure you check for secrets before committing. You must run gitleaks before committing. The commit message should follow conventionalcommits standards and be a general synopsis of the changes."

# Settings: environment variable > config file > built-in default.
DOTFILES_BECOME="$(pick "${DOTFILES_BECOME:-}" sync.become "")"
OPENROUTER_API_KEY="$(pick "${OPENROUTER_API_KEY:-}" commit.api_key "")"
OPENROUTER_MODEL="$(pick "${OPENROUTER_MODEL:-}" commit.model openai/gpt-4o-mini)"
OPENROUTER_URL="$(pick "${OPENROUTER_URL:-}" commit.url https://openrouter.ai/api/v1/chat/completions)"
DOTFILES_COMMIT_PROMPT="$(pick "${DOTFILES_COMMIT_PROMPT:-}" commit.prompt "$_default_prompt")"

# Become (sudo) password — prompt by default. Ansible runs sudo with -n, so a
# needed-but-missing password kills the run mid-play. Set become=none (config
# sync.become, or DOTFILES_BECOME) only for genuine NOPASSWD / headless sudo.
become=(--ask-become-pass)
case "$DOTFILES_BECOME" in none|no|0) become=() ;; esac

play() {  # play <playbook> [extra ansible-playbook args...]
  local pb="$1"; shift
  ( cd "$DOTFILES_DIR" && ansible-playbook "$pb" --limit "$HOST" "${become[@]}" "$@" )
}

add_host() {  # add-host [HOSTNAME] — register a new machine so it can be configured
  local host="${1:-$HOST}"
  case "$host" in
    ""|-*)             die "usage: dotfiles add-host [HOSTNAME]" ;;
    *[!A-Za-z0-9._-]*) die "invalid hostname: '${host}'" ;;
  esac

  # Map the running OS (or $DOTFILES_FAMILY) to an inventory family group.
  local family="${DOTFILES_FAMILY:-}"
  if [ -z "$family" ]; then
    # shellcheck disable=SC1091
    . /etc/os-release 2>/dev/null || true
    case " ${ID:-} ${ID_LIKE:-} " in
      *arch*)                   family=archlinux ;;
      *debian*|*ubuntu*)        family=debian ;;
      *rhel*|*fedora*|*centos*) family=redhat ;;
      *) die "Cannot detect OS family — set DOTFILES_FAMILY=archlinux|debian|redhat." ;;
    esac
  fi
  case "$family" in
    archlinux|debian|redhat) ;;
    *) die "Unknown family '${family}' (want archlinux, debian or redhat)." ;;
  esac

  local inv="${DOTFILES_DIR}/inventory/hosts.yml"
  local hv="${DOTFILES_DIR}/inventory/host_vars/${host}.yml"
  local py; py="$(command -v python3 || command -v python)" \
    || die "python not found — run ${DOTFILES_DIR}/bootstrap.sh first."

  say "Registering '${host}' in the '${family}' group"

  # 1) Inventory entry — surgical line insert, comment-preserving and idempotent.
  local res
  res="$("$py" - "$inv" "$family" "$host" <<'PY'
import re, sys
path, family, host = sys.argv[1:4]
with open(path) as f:
    lines = f.readlines()
if any(re.match(r"^ {8}" + re.escape(host) + r":\s*$", ln) for ln in lines):
    print("exists"); sys.exit(0)
gi = next((i for i, ln in enumerate(lines)
           if re.match(r"^    " + re.escape(family) + r":\s*$", ln)), None)
if gi is None:
    sys.exit(2)
hi = None
for j in range(gi + 1, len(lines)):
    if re.match(r"^    [A-Za-z_]\w*:\s*$", lines[j]):
        break
    if lines[j].strip() in ("hosts:", "hosts: {}"):
        hi = j; break
if hi is None:
    sys.exit(3)
if lines[hi].strip() == "hosts: {}":
    lines[hi] = "      hosts:\n"
lines[hi + 1:hi + 1] = ["        %s:\n" % host,
                        "          ansible_connection: local\n"]
with open(path, "w") as f:
    f.writelines(lines)
print("added")
PY
)" || die "Could not update ${inv} (group '${family}' missing?)."
  case "$res" in
    added) say "  inventory: added under '${family}' (ansible_connection: local)" ;;
    *)     warn "  inventory: '${host}' already present — left unchanged" ;;
  esac

  # 2) host_vars file — opt into the dotfile roles; never clobber an existing one.
  if [ -e "$hv" ]; then
    warn "  host_vars: ${host}.yml already exists — left unchanged"
  else
    mkdir -p "$(dirname "$hv")"
    cat > "$hv" <<EOF
---
# HOST layer — ${host}. Created by 'dotfiles add-host'.
# Per-machine deviations go here (see the README "Layering model").

# Roles run for this host beyond the common baseline. Trim to taste.
additional_roles:
  - zsh
  - cli
  - git

# Per-host package additions (use names valid for this OS family):
# common_packages_host:
#   - ripgrep
EOF
    say "  host_vars: created ${host}.yml"
  fi

  printf '\n%sNext:%s review the two files, then apply this machine:\n  dotfiles sync\n' "$b" "$n"
}

scan_secrets() {  # run the first available well-known secret scanner on staged changes
  if command -v gitleaks >/dev/null 2>&1; then
    say "  scanning staged changes with gitleaks"
    # `protect --staged` checks the index (uncommitted) — the documented v8 pre-commit mode.
    gitleaks protect --staged --redact --no-banner \
      || die "gitleaks flagged a potential secret — commit aborted. Fix or unstage, then retry."
  elif command -v git-secrets >/dev/null 2>&1; then
    say "  scanning with git-secrets"
    git secrets --scan \
      || die "git-secrets flagged a potential secret — commit aborted."
  else
    warn "  no secret scanner found (install gitleaks or git-secrets) — skipping scan"
  fi
}

# _llm_chat <system_prompt> <user_prompt>
# Prints the model's reply on stdout; on failure prints to stderr and returns 1.
# Uses OPENROUTER_API_KEY / OPENROUTER_MODEL / OPENROUTER_URL (resolved above).
_llm_chat() {
  local py; py="$(command -v python3 || command -v python)" || return 1
  [ -n "${OPENROUTER_API_KEY:-}" ] || { echo "openrouter: no API key set" >&2; return 1; }
  OR_KEY="$OPENROUTER_API_KEY" OR_MODEL="$OPENROUTER_MODEL" OR_URL="$OPENROUTER_URL" \
  OR_SYSTEM="$1" OR_USER="$2" "$py" - <<'PY'
import json, os, sys, urllib.request, urllib.error
payload = json.dumps({
    "model": os.environ["OR_MODEL"],
    "messages": [
        {"role": "system", "content": os.environ["OR_SYSTEM"]},
        {"role": "user", "content": os.environ["OR_USER"]},
    ],
})
req = urllib.request.Request(
    os.environ["OR_URL"], data=payload.encode(),
    headers={"Authorization": "Bearer " + os.environ["OR_KEY"],
             "Content-Type": "application/json",
             "X-Title": "dotfiles"},
)
try:
    with urllib.request.urlopen(req, timeout=60) as resp:
        data = json.load(resp)
except urllib.error.HTTPError as exc:
    body = exc.read().decode("utf-8", "replace")[:400]
    sys.stderr.write("openrouter: HTTP %s — %s\n" % (exc.code, body)); sys.exit(1)
except Exception as exc:
    sys.stderr.write("openrouter: %s\n" % exc); sys.exit(1)
if isinstance(data, dict) and data.get("error"):
    sys.stderr.write("openrouter: %s\n" % json.dumps(data["error"])[:400]); sys.exit(1)
choices = data.get("choices") or []
message = (choices[0].get("message") or {}) if choices else {}
# Most models put the text in .content; some reasoning models leave it in .reasoning.
text = message.get("content")
if not (isinstance(text, str) and text.strip()):
    text = message.get("reasoning")
if not (isinstance(text, str) and text.strip()):
    fr = choices[0].get("finish_reason") if choices else None
    sys.stderr.write("openrouter: model returned no message content "
                     "(finish_reason=%s); try a non-reasoning model\n" % fr); sys.exit(1)
print(text.strip())
PY
}

llm_commit_message() {  # print an LLM commit message from the staged diff, or fail
  local diff
  diff="$( { git diff --cached --stat; echo; git diff --cached; } 2>/dev/null | head -c 12000 || true )"
  _llm_chat \
    "You write git commit messages for a dotfiles repository. Reply with ONLY the commit message text — no preamble, no code fences." \
    "${DOTFILES_COMMIT_PROMPT}"$'\n\nStaged changes:\n\n'"${diff}"
}

do_commit() {  # commit — stage all changes, scan for secrets, commit with a dated message
  command -v git >/dev/null 2>&1 || die "git not found."
  cd "$DOTFILES_DIR" || die "cannot enter ${DOTFILES_DIR}."
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "${DOTFILES_DIR} is not a git repository — run 'git init' there first."

  if [ -z "$(git status --porcelain)" ]; then
    say "Nothing to commit — working tree clean."
    return 0
  fi

  say "Staging all changes in ${DOTFILES_DIR}"
  git add -A

  scan_secrets   # aborts the commit if a scanner flags a secret

  local stamp msg=""
  stamp="$(date '+%Y-%m-%d %H:%M')"
  if [ -n "${OPENROUTER_API_KEY:-}" ]; then
    say "  generating a commit message via OpenRouter (${OPENROUTER_MODEL})"
    msg="$(llm_commit_message)" || { warn "  OpenRouter call failed — using the generic message"; msg=""; }
  fi
  if [ -n "$msg" ]; then
    git commit --quiet -F - <<<"$msg"
    say "Committed (LLM-generated message)"
  else
    git commit --quiet -m "Update ${stamp}" -m "$(git status --short)"
    say "Committed 'Update ${stamp}'"
  fi
}

do_review() {  # review — dry-run the playbook and summarise the pending changes
  [ -n "${OPENROUTER_API_KEY:-}" ] \
    || die "review needs an LLM — set OPENROUTER_API_KEY (or use 'dotfiles check' for the raw diff)."
  say "Previewing ${HOST} (dry-run) and summarising changes"
  local tmp rc=0
  tmp="$(mktemp)" || die "could not create a temp file."
  # Show the check output live (tee) AND capture stdout for the LLM. The
  # --ask-become-pass prompt reads from the tty and is unaffected by the pipe;
  # stderr (prompt, warnings) is left on the terminal, not captured.
  set +o pipefail
  play site.yml --check --diff "$@" | tee "$tmp"
  rc=${PIPESTATUS[0]}
  set -o pipefail
  local diff summary
  diff="$(head -c 20000 "$tmp" || true)"
  rm -f "$tmp"
  if [ -z "${diff//[[:space:]]/}" ]; then
    warn "  no dry-run output captured — nothing to summarise"
    return "$rc"
  fi
  say "  summarising via OpenRouter (${OPENROUTER_MODEL})"
  summary="$(_llm_chat \
    "You explain the output of an Ansible 'ansible-playbook --check --diff' dry run to a developer. Summarise, in plain English, what applying it would change on this machine: group changes by role/task, name the files and packages touched, and explicitly flag anything destructive (file overwrites, removals, service restarts). If nothing would change, say so in one line. Be concise; use short bullets. Do not invent changes not present in the output." \
    "$diff")" || { warn "  LLM summary failed — see the dry-run output above"; return "$rc"; }
  printf '\n%sWhat sync would change:%s\n%s\n' "$b" "$n" "$summary"
  return "$rc"
}

do_doctor() {  # doctor — health-check this setup; LLM suggests fixes when a key is set
  local report="" fail=0
  rec() {  # rec <OK|WARN|FAIL> <message>
    local tag="$1"; shift
    local col="$g"; case "$tag" in WARN) col="$y";; FAIL) col="$r"; fail=1;; esac
    printf '%s[%s]%s %s\n' "$col" "$tag" "$n" "$*"
    report+="[$tag] $*"$'\n'
  }
  local py; py="$(command -v python3 || command -v python || true)"

  say "Diagnosing ${HOST} <- ${DOTFILES_DIR}"

  # 1. Core dependencies
  command -v ansible-playbook >/dev/null 2>&1 && rec OK "ansible-playbook present" || rec FAIL "ansible-playbook missing — run ${DOTFILES_DIR}/bootstrap.sh"
  [ -n "$py" ] && rec OK "python present ($py)" || rec FAIL "python3 missing — required for config + LLM features"
  command -v git >/dev/null 2>&1 && rec OK "git present" || rec FAIL "git missing"

  # 2. Secret scanner (used by 'commit')
  if command -v gitleaks >/dev/null 2>&1; then rec OK "secret scanner: gitleaks"
  elif command -v git-secrets >/dev/null 2>&1; then rec OK "secret scanner: git-secrets"
  else rec WARN "no secret scanner (gitleaks/git-secrets) — 'commit' will not scan"; fi

  # 3. AI configuration
  if [ -n "${OPENROUTER_API_KEY:-}" ]; then rec OK "OPENROUTER_API_KEY set (model ${OPENROUTER_MODEL})"
  else rec WARN "OPENROUTER_API_KEY unset — commit/review/doctor AI features disabled"; fi

  # 4. CLI symlink + PATH
  local cli="$HOME/.local/bin/dotfiles"
  if [ -L "$cli" ]; then
    local tgt; tgt="$(readlink -f "$cli" 2>/dev/null || true)"
    if [ "$tgt" = "$(readlink -f "$DOTFILES_DIR/bin/dotfiles" 2>/dev/null || true)" ]; then
      rec OK "CLI symlinked: $cli"
    else rec WARN "CLI symlink points to '$tgt', not $DOTFILES_DIR/bin/dotfiles — run 'dotfiles sync'"; fi
  elif [ -e "$cli" ]; then rec WARN "$cli exists but is not a symlink"
  else rec WARN "$cli missing — run 'dotfiles sync' (cli role)"; fi
  case ":$PATH:" in *":$HOME/.local/bin:"*) rec OK "~/.local/bin on PATH";; *) rec WARN "~/.local/bin not on PATH";; esac

  # 5. Config file: presence + parse
  if [ -f "$DOTFILES_CONFIG" ]; then
    if [ -n "$py" ] && "$py" - "$DOTFILES_CONFIG" <<'PY' >/dev/null 2>&1
import sys, tomllib
with open(sys.argv[1], "rb") as fh: tomllib.load(fh)
PY
    then rec OK "config parses: $DOTFILES_CONFIG"
    else rec FAIL "config is invalid TOML: $DOTFILES_CONFIG"; fi
  else rec WARN "no config at $DOTFILES_CONFIG — run 'dotfiles config'"; fi

  # 6. Managed symlinks — flag dangling (target missing)
  local link
  for link in "$HOME/.zshrc" "$HOME/.gitconfig" "$HOME/.config/dotfiles/config.toml" "$cli"; do
    if [ -L "$link" ] && [ ! -e "$link" ]; then rec FAIL "dangling symlink: $link -> $(readlink "$link")"; fi
  done

  # 7. Dangling links in ~/.local/bin
  if [ -d "$HOME/.local/bin" ]; then
    local broken; broken="$(find -L "$HOME/.local/bin" -maxdepth 1 -type l 2>/dev/null || true)"
    [ -n "$broken" ] && rec WARN "broken links in ~/.local/bin: $(echo "$broken" | tr '\n' ' ')" || rec OK "no broken links in ~/.local/bin"
  fi

  # 8. Host registration
  if ansible-inventory -i "$DOTFILES_DIR/inventory/hosts.yml" --host "$HOST" >/dev/null 2>&1; then
    rec OK "host '${HOST}' registered in inventory"
  else rec WARN "host '${HOST}' not in inventory — run 'dotfiles add-host'"; fi

  # 9. Playbook syntax
  if ( cd "$DOTFILES_DIR" && ansible-playbook site.yml --syntax-check >/dev/null 2>&1 ); then
    rec OK "site.yml syntax OK"
  else rec FAIL "site.yml failed --syntax-check — the repo is broken"; fi

  # 10. Working tree (informational)
  local dirty; dirty="$(git -C "$DOTFILES_DIR" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
  [ "${dirty:-0}" -gt 0 ] && rec OK "${dirty} uncommitted change(s) — run 'dotfiles commit'" || rec OK "working tree clean"

  # AI remediation (only when configured)
  if [ -n "${OPENROUTER_API_KEY:-}" ]; then
    local advice
    say "  asking OpenRouter for fixes (${OPENROUTER_MODEL})"
    advice="$(_llm_chat \
      "You are a Linux dotfiles troubleshooting assistant. Given a health-check report (lines tagged [OK]/[WARN]/[FAIL]) for an Ansible-managed dotfiles setup driven by a 'dotfiles' CLI (commands: sync, add-host, config, commit, secrets), give concrete fixes ONLY for [WARN]/[FAIL] lines, as a short ordered list with the exact command to run. If everything is [OK], reply 'No action needed.' Be concise." \
      "$report")" \
      && printf '\n%sSuggested fixes:%s\n%s\n' "$b" "$n" "$advice" \
      || warn "  LLM advice failed — findings above stand on their own"
  else
    printf '\n%sTip:%s set OPENROUTER_API_KEY for AI-suggested fixes.\n' "$b" "$n"
  fi

  [ "$fail" -eq 0 ] || return 1
}

ensure_config() {  # create the config (commented template) if it does not exist
  [ -f "$DOTFILES_CONFIG" ] && return 0
  mkdir -p "$(dirname "$DOTFILES_CONFIG")"
  cat > "$DOTFILES_CONFIG" <<'EOF'
# dotfiles config (TOML). Values here override built-in defaults; a matching
# environment variable still overrides this file. Needs Python >= 3.11.

[commit]
# LLM-generated commit messages for `dotfiles commit` (active once an API key is
# set — prefer the OPENROUTER_API_KEY env var or a Bitwarden note for the key).
# model   = "openai/gpt-4o-mini"
# url     = "https://openrouter.ai/api/v1/chat/completions"
# api_key = "sk-or-..."
# prompt  = """
# Commit the changes in this dotfiles repository. Ensure you check for secrets
# before committing. You must run gitleaks before committing. The commit message
# should follow conventionalcommits standards and be a general synopsis of the
# changes.
# """

[sync]
# become = "none"   # skip the sudo-password prompt (NOPASSWD / headless sudo)
EOF
  chmod 600 "$DOTFILES_CONFIG"
  say "Created ${DOTFILES_CONFIG}"
}

usage() {
  cat <<EOF
${b}dotfiles${n} — sync this machine to ${DOTFILES_DIR}

${b}Usage:${n} dotfiles <command> [extra ansible-playbook args...]

${b}Commands:${n}
  sync      Apply the playbook to this host (main command)
  check     Preview changes without applying them (--check --diff)
  secrets   Pull secrets from Bitwarden (bitwarden role only)
  update    Install/refresh Galaxy collections (requirements.yml)
  add-host  Register this machine (or HOST) in the inventory + host_vars
  commit    Stage, secret-scan, then commit (LLM message if OPENROUTER_API_KEY set)
  review    Dry-run the playbook and summarise pending changes (needs OPENROUTER_API_KEY)
  doctor    Health-check this setup; LLM suggests fixes if OPENROUTER_API_KEY is set
  edit      Open the repo in \$EDITOR
  config    Create/edit ~/.config/dotfiles/config.toml (prompt, model, become)
  status    Show repo path, host and git working-tree status
  help      Show this help

Extra args pass through to ansible-playbook, e.g.:
  dotfiles sync --skip-tags bitwarden     # config only, skip secret-pulling
  dotfiles sync --tags packages
  dotfiles check --tags additional_roles

Env: DOTFILES_DIR (repo, auto-detected) · DOTFILES_HOST (default: \$(hostname))
     DOTFILES_BECOME=none to skip the sudo-password prompt (NOPASSWD/headless)
     DOTFILES_FAMILY=archlinux|debian|redhat to override add-host detection
     OPENROUTER_API_KEY enables an LLM commit message for 'commit';
       OPENROUTER_MODEL (default openai/gpt-4o-mini) + DOTFILES_COMMIT_PROMPT tune it
     Any of the above can live in ~/.config/dotfiles/config.toml — 'dotfiles config'
EOF
}

cmd="${1:-help}"; shift 2>/dev/null || true
case "$cmd" in
  sync)            say "Applying ${HOST} <- ${DOTFILES_DIR}"; play site.yml "$@" ;;
  check|diff)      say "Previewing ${HOST} (no changes applied)"; play site.yml --check --diff "$@" ;;
  secrets)         say "Pulling secrets for ${HOST}"
                   # Only the bitwarden role: scope to the additional_roles play
                   # (skips the common baseline) and override the role list.
                   play site.yml --tags additional_roles -e '{"additional_roles":["bitwarden"]}' "$@" ;;
  update)          say "Refreshing Galaxy collections"
                   ( cd "$DOTFILES_DIR" && ansible-galaxy collection install -r requirements.yml "$@" ) ;;
  add-host)        add_host "$@" ;;
  commit)          do_commit "$@" ;;
  review)          do_review "$@" ;;
  doctor)          do_doctor "$@" ;;
  config)          ensure_config; say "config: ${DOTFILES_CONFIG}"; ( exec "${EDITOR:-vi}" "$DOTFILES_CONFIG" ) ;;
  edit)            ( cd "$DOTFILES_DIR" && exec "${EDITOR:-vi}" . ) ;;
  status)          printf '%srepo%s %s\n%shost%s %s\n' "$b" "$n" "$DOTFILES_DIR" "$b" "$n" "$HOST"
                   git -C "$DOTFILES_DIR" status -sb ;;
  version|-V|--version) git -C "$DOTFILES_DIR" describe --always --dirty 2>/dev/null || echo unknown ;;
  help|-h|--help)  usage ;;
  *)               warn "Unknown command: ${cmd}"; usage; exit 1 ;;
esac
